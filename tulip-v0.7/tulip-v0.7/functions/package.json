{
  "name": "tulip-firebase-functions",
  "description": "Firebase Cloud Functions for Tulip e-commerce platform",
  "type": "module",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "lint": "eslint .",
    "build": "tsc",
    "serve": "firebase emulators:start --only functions",
